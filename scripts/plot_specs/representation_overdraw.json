{
  "input": "../../results/representation_overdraw.csv",
  "output": "../../results/plots/representation_overdraw.png",
  "kind": "line",
  "x": "measured_overdraw",
  "y": "pass_3_time_median_ms",
  "series": "renderer_name",
  "aggregate": "median",
  "error": { "mode": "minmax" },
  "sort_x": "numeric",
  "filter": {
    "material-count": 1,
    "window-width": 1920,
    "window-height": 1080
  },
  "labels": {
    "title": "Renderer cost as overdraw increases",
    "x": "Measured overdraw (fragments / visible pixel)",
    "y": "Median GPU time (ms)",
    "legend": "Renderer"
  },
  "series_labels": {
    "Forward": "Forward",
    "ForwardPrepass": "Forward + depth pre-pass",
    "Deferred": "Deferred",
    "DeferredPrepass": "Deferred + depth pre-pass",
    "TVB": "TVB (direct)",
    "TVBGBuffer": "TVB + G-buffer"
  },
  "figure": { "width": 10, "height": 6, "dpi": 180 },
  "style": { "grid": true }
}
